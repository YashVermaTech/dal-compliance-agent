# ============================================================
# DAL-Aware Compliance Agent — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# Groq LLM (free tier — https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Pinecone Vector DB (free tier — https://www.pinecone.io)
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENV=your_pinecone_environment_here  # e.g. us-east-1-aws

# Backend URL (set this in HuggingFace Spaces secrets)
# For local dev: http://localhost:8000
# For production: https://your-app.onrender.com
BACKEND_URL=http://localhost:8000
